# Service identity
SERVICE_NAME=thronos-pawssworfmanager
SERVICE_ENV=production
SERVICE_PORT=8080
SERVICE_LOG_LEVEL=info

# Railway deployment boundary
RAILWAY_SERVICE_ROLE=v0-boundary
RAILWAY_REGION=us-west1
RAILWAY_PUBLIC_DOMAIN=change-me.railway.app

# Runtime paths (50GB attached volume expected)
SERVICE_DATA_ROOT=/data
PATH_BLOBS=/data/blobs
PATH_MANIFESTS=/data/manifests
PATH_TOMBSTONES=/data/tombstones
PATH_EXPORTS=/data/transfers/exports
PATH_IMPORTS=/data/transfers/imports
PATH_LOGS=/data/logs
PATH_AUDIT=/data/audit

# Readiness/health route guidance
HEALTH_ROUTE=/healthz
READINESS_ROUTE=/readyz
READINESS_REQUIRE_WRITABLE_VOLUME=true

# Metadata DB (configured for isolation, feature use may be deferred)
DATABASE_URL=postgresql://vault:vault@db:5432/vaultdb

# Optional object storage config (no implementation in this pass)
BLOB_STORAGE_ENDPOINT=https://object.example.internal
BLOB_STORAGE_BUCKET=vault-ciphertext
BLOB_STORAGE_ACCESS_KEY=change-me
BLOB_STORAGE_SECRET_KEY=change-me

# Thronos config present but writes disabled in v0
THRONOS_NETWORK=testnet
THRONOS_RPC_URL=https://rpc.example.internal
THRONOS_ATTESTATION_CONTRACT=0x0000000000000000000000000000000000000000
ATTESTATION_CONFIRMATIONS=1
ENABLE_BLOCKCHAIN_WRITES=false

# Feature gates for v0 boundary
ENABLE_AUTH_RUNTIME=false
ENABLE_ENCRYPTION_RUNTIME=false
ENABLE_BLOB_STORAGE_RUNTIME=false
ENABLE_EXPORT_IMPORT_RUNTIME=false

# Operational limits
MAX_BLOB_BYTES=1048576
REQUEST_TIMEOUT_MS=15000
