# Service
SERVICE_NAME=thronos-pawssworfmanager
SERVICE_ENV=development
SERVICE_PORT=8080

# Metadata DB
DATABASE_URL=postgresql://vault:vault@localhost:5432/vaultdb

# Object storage (ciphertext blobs)
BLOB_STORAGE_ENDPOINT=http://localhost:9000
BLOB_STORAGE_BUCKET=vault-ciphertext
BLOB_STORAGE_ACCESS_KEY=change-me
BLOB_STORAGE_SECRET_KEY=change-me

# Thronos attestation
THRONOS_NETWORK=testnet
THRONOS_RPC_URL=http://localhost:8545
THRONOS_ATTESTATION_CONTRACT=0x0000000000000000000000000000000000000000
ATTESTATION_CONFIRMATIONS=1

# Security / API
API_AUTH_MODE=token
MAX_BLOB_BYTES=1048576
REQUEST_TIMEOUT_MS=15000
